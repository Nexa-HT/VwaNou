# Application Settings
APP_NAME=VwaNou API
APP_ENV=development

# Database Configuration
# Make sure PostgreSQL is running on localhost:5432
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/vwanou

# CORS - Add your frontend URL here
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://localhost:3000

# JWT Security - Generate a strong secret key for production
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# API docs are enabled by default in development and should stay disabled in production.
ENABLE_DOCS=true

# AI Service (placeholder for future integration)
AI_SERVICE_TYPE=mock
# AI_API_KEY=your-api-key-here

# Anthropic (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_MAX_TOKENS=400
